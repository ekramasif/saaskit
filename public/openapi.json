{
  "openapi": "3.0.0",
  "info": {
    "title": "AI SaaS Starter Kit API",
    "version": "1.0.0",
    "description": "Production-ready Next.js 15 AI SaaS API with authentication, billing, and AI integration. This API provides endpoints for user registration, Stripe payment processing, and webhook handling.",
    "contact": {
      "name": "API Support",
      "email": "support@example.com"
    },
    "license": {
      "name": "MIT",
      "url": "https://opensource.org/licenses/MIT"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Development server"
    },
    {
      "url": "https://yourdomain.com",
      "description": "Production server"
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "User authentication and registration endpoints. Handle user registration with email/password and OAuth providers (Google, GitHub)."
    },
    {
      "name": "Billing",
      "description": "Stripe checkout and subscription management. Create checkout sessions for plan purchases and manage subscriptions."
    },
    {
      "name": "Webhooks",
      "description": "External service webhooks. Receive and process events from Stripe for payment confirmations and subscription updates."
    }
  ],
  "paths": {
    "/api/auth/register": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Register a new user",
        "description": "Create a new user account with email and password. The user will be created with 100 free credits and automatically assigned the USER role. Password must be at least 8 characters long and will be hashed using bcrypt before storage.",
        "operationId": "registerUser",
        "requestBody": {
          "required": true,
          "description": "User registration details",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              },
              "examples": {
                "basic": {
                  "summary": "Basic registration",
                  "value": {
                    "name": "John Doe",
                    "email": "john.doe@example.com",
                    "password": "SecurePass123!"
                  }
                },
                "premium": {
                  "summary": "Premium user",
                  "value": {
                    "name": "Jane Smith",
                    "email": "jane.smith@company.com",
                    "password": "MyStr0ngP@ssw0rd"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created successfully. The user is now registered and can sign in.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegisterResponse"
                },
                "examples": {
                  "success": {
                    "summary": "Successful registration",
                    "value": {
                      "success": true,
                      "user": {
                        "id": "clx1234567890abcdef",
                        "name": "John Doe",
                        "email": "john.doe@example.com",
                        "credits": 100,
                        "createdAt": "2024-01-15T10:30:00.000Z"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation error - Invalid input data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "examples": {
                  "invalidEmail": {
                    "summary": "Invalid email format",
                    "value": {
                      "error": "Validation failed",
                      "message": "Invalid email address"
                    }
                  },
                  "shortPassword": {
                    "summary": "Password too short",
                    "value": {
                      "error": "Validation failed",
                      "message": "Password must be at least 8 characters"
                    }
                  },
                  "shortName": {
                    "summary": "Name too short",
                    "value": {
                      "error": "Validation failed",
                      "message": "Name must be at least 2 characters"
                    }
                  }
                }
              }
            }
          },
          "409": {
            "description": "Conflict - User already exists with this email",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "examples": {
                  "userExists": {
                    "summary": "Email already registered",
                    "value": {
                      "error": "User already exists",
                      "message": "A user with this email already exists"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "examples": {
                  "serverError": {
                    "summary": "Database error",
                    "value": {
                      "error": "Internal server error",
                      "message": "Failed to create user account"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/create-checkout": {
      "post": {
        "tags": ["Billing"],
        "summary": "Create Stripe checkout session",
        "description": "Create a Stripe checkout session for subscription purchase. User must be authenticated. Returns a URL to redirect the user to Stripe's hosted checkout page. Available plans: Free (no checkout needed), Pro ($19/month), Business ($49/month).",
        "operationId": "createCheckout",
        "security": [
          {
            "sessionAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "description": "Checkout session details with Stripe price ID and plan name",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CheckoutRequest"
              },
              "examples": {
                "proPlan": {
                  "summary": "Pro Plan ($19/month)",
                  "value": {
                    "priceId": "price_1OXd9KExample123456",
                    "planName": "Pro Plan"
                  }
                },
                "businessPlan": {
                  "summary": "Business Plan ($49/month)",
                  "value": {
                    "priceId": "price_1OXd9LExample789012",
                    "planName": "Business Plan"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Checkout session created successfully. Redirect user to the returned URL.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CheckoutResponse"
                },
                "examples": {
                  "success": {
                    "summary": "Successful checkout session",
                    "value": {
                      "url": "https://checkout.stripe.com/c/pay/cs_test_a1B2c3D4e5F6g7H8i9J0k1L2m3N4o5P6q7R8s9T0"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request - Missing required fields",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "examples": {
                  "missingFields": {
                    "summary": "Missing required fields",
                    "value": {
                      "error": "Bad request",
                      "message": "Missing required fields: priceId and planName"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - User not authenticated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "examples": {
                  "notAuthenticated": {
                    "summary": "User not logged in",
                    "value": {
                      "error": "Unauthorized",
                      "message": "You must be logged in to create a checkout session"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error - Stripe error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "examples": {
                  "stripeError": {
                    "summary": "Stripe API error",
                    "value": {
                      "error": "Internal server error",
                      "message": "Failed to create Stripe checkout session"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/webhooks/stripe": {
      "post": {
        "tags": ["Webhooks"],
        "summary": "Stripe webhook endpoint",
        "description": "Receive and process Stripe webhook events. This endpoint handles payment confirmations, subscription updates, and cancellations. Stripe will send events like checkout.session.completed, customer.subscription.updated, and customer.subscription.deleted. The request must include a valid Stripe signature header for security.",
        "operationId": "stripeWebhook",
        "parameters": [
          {
            "name": "stripe-signature",
            "in": "header",
            "required": true,
            "description": "Stripe webhook signature for request verification",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "description": "Stripe webhook event data",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StripeWebhookEvent"
              },
              "examples": {
                "checkoutCompleted": {
                  "summary": "Checkout session completed",
                  "value": {
                    "id": "evt_1OXd9KExample123456",
                    "type": "checkout.session.completed",
                    "data": {
                      "object": {
                        "id": "cs_test_a1B2c3D4e5F6g7H8i9J0k1L2m3N4o5P6q7R8s9T0",
                        "customer": "cus_Example123456",
                        "subscription": "sub_Example789012",
                        "metadata": {
                          "userId": "clx1234567890abcdef",
                          "planName": "Pro Plan"
                        }
                      }
                    }
                  }
                },
                "subscriptionUpdated": {
                  "summary": "Subscription updated",
                  "value": {
                    "id": "evt_1OXd9LExample789012",
                    "type": "customer.subscription.updated",
                    "data": {
                      "object": {
                        "id": "sub_Example789012",
                        "status": "active",
                        "current_period_start": 1705312800,
                        "current_period_end": 1707991200
                      }
                    }
                  }
                },
                "subscriptionDeleted": {
                  "summary": "Subscription canceled",
                  "value": {
                    "id": "evt_1OXd9MExample345678",
                    "type": "customer.subscription.deleted",
                    "data": {
                      "object": {
                        "id": "sub_Example789012",
                        "status": "canceled"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Webhook processed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "received": {
                      "type": "boolean",
                      "example": true
                    }
                  }
                },
                "examples": {
                  "success": {
                    "summary": "Event processed",
                    "value": {
                      "received": true
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid webhook signature or payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "examples": {
                  "invalidSignature": {
                    "summary": "Invalid signature",
                    "value": {
                      "error": "Webhook Error",
                      "message": "Invalid webhook signature"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error while processing webhook",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "examples": {
                  "processingError": {
                    "summary": "Processing failed",
                    "value": {
                      "error": "Internal server error",
                      "message": "Failed to process webhook event"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "sessionAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "authjs.session-token",
        "description": "Session-based authentication using NextAuth. After signing in, the session cookie will be automatically included in requests."
      }
    },
    "schemas": {
      "RegisterRequest": {
        "type": "object",
        "required": ["name", "email", "password"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 2,
            "description": "User's full name",
            "example": "John Doe"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "User's email address (must be unique)",
            "example": "john.doe@example.com"
          },
          "password": {
            "type": "string",
            "minLength": 8,
            "format": "password",
            "description": "User's password (min 8 characters, will be hashed)",
            "example": "SecurePass123!"
          }
        }
      },
      "RegisterResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Whether the registration was successful",
            "example": true
          },
          "user": {
            "$ref": "#/components/schemas/User"
          }
        }
      },
      "CheckoutRequest": {
        "type": "object",
        "required": ["priceId", "planName"],
        "properties": {
          "priceId": {
            "type": "string",
            "description": "Stripe price ID for the subscription plan",
            "example": "price_1OXd9KExample123456"
          },
          "planName": {
            "type": "string",
            "description": "Name of the subscription plan (Pro Plan, Business Plan)",
            "example": "Pro Plan",
            "enum": ["Pro Plan", "Business Plan"]
          }
        }
      },
      "CheckoutResponse": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Stripe checkout URL where user should be redirected",
            "example": "https://checkout.stripe.com/c/pay/cs_test_a1B2c3D4e5F6g7H8i9J0k1L2m3N4o5P6q7R8s9T0"
          }
        }
      },
      "StripeWebhookEvent": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the event",
            "example": "evt_1OXd9KExample123456"
          },
          "type": {
            "type": "string",
            "description": "Event type from Stripe",
            "example": "checkout.session.completed",
            "enum": [
              "checkout.session.completed",
              "customer.subscription.updated",
              "customer.subscription.deleted",
              "invoice.payment_succeeded",
              "invoice.payment_failed"
            ]
          },
          "data": {
            "type": "object",
            "description": "Event data containing the Stripe object",
            "properties": {
              "object": {
                "type": "object",
                "description": "The Stripe object related to the event"
              }
            }
          }
        }
      },
      "User": {
        "type": "object",
        "description": "User account information",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique user identifier (CUID)",
            "example": "clx1234567890abcdef"
          },
          "name": {
            "type": "string",
            "description": "User's full name",
            "example": "John Doe"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "User's email address",
            "example": "john.doe@example.com"
          },
          "credits": {
            "type": "integer",
            "description": "Available AI credits for the user",
            "example": 100,
            "default": 100
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Account creation timestamp",
            "example": "2024-01-15T10:30:00.000Z"
          },
          "roles": {
            "type": "array",
            "description": "User's assigned roles",
            "items": {
              "type": "string",
              "enum": ["USER", "ADMIN", "SUPER_ADMIN"]
            },
            "example": ["USER"]
          }
        }
      },
      "Error": {
        "type": "object",
        "description": "Error response format",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error type or category",
            "example": "Validation failed"
          },
          "message": {
            "type": "string",
            "description": "Detailed error message",
            "example": "The email address is already registered"
          }
        }
      }
    }
  }
}
